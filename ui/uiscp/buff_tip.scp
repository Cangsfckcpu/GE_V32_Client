func BUFF_Sinfonia(level)
{
  var stat = 0;
  if(level <= 1){
    stat = 0;
  }else if(level <= 3){
    stat = 1;
  }else if(level <=5){
    stat = 2;
  }else if(level <= 7){
    stat = 3;
  }else if(level <= 9){
    stat = 4;
  }else if(level <= 11){
    stat = 5;
  }else if(level >= 12){
    stat = 6;
  }
  if(level <=10){
    return IMCFormat("<$>500177</>", level, level, stat, stat);
  }else if(level >= 11){
    return IMCFormat("<$>500177</>", level, 10+level, stat, stat);
  }
}
